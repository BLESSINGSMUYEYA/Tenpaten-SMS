generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id                String           @id @default(uuid())
  name              String
  type              SchoolType
  district          String
  country           String           @default("Malawi")
  logoUrl           String?
  motto             String?
  address           String?
  phone             String?
  email             String?
  schoolCode        String           @unique
  subscriptionPlan  String           @default("basic")
  subscriptionStart DateTime?
  subscriptionEnd   DateTime?
  isActive          Boolean          @default(true)
  setupComplete     Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  isDeleted         Boolean          @default(false)
  timetableConfig   Json?
  
  featuresAttendance      Boolean          @default(true) @map("features_attendance")
  featuresGrades          Boolean          @default(true) @map("features_grades")
  featuresFees            Boolean          @default(true) @map("features_fees")
  featuresCommunication   Boolean          @default(true) @map("features_communication")
  academicYears     AcademicYear[]
  attendance        Attendance[]
  classes           Class[]
  feePayments       FeePayment[]
  feeStructures     FeeStructure[]
  grades            Grade[]
  gradingScales     GradingScale[]
  invoices          Invoice[]
  studentProfiles   StudentProfile[]
  subjects          Subject[]
  terms             Term[]
  timetableSlots    TimetableSlot[]
  users             User[]

  @@index([isDeleted])
  @@index([isActive, isDeleted])
  @@map("schools")
}

model User {
  id                      String               @id @default(uuid())
  schoolId                String?
  firstName               String
  lastName                String
  email                   String?
  phone                   String?
  passwordHash            String
  role                    UserRole
  isActive                Boolean              @default(true)
  mustChangePassword      Boolean              @default(false)
  lastLogin               DateTime?
  photoUrl                String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  isDeleted               Boolean              @default(false)
  username                String?
  // ---- Account lockout ----
  failedLoginAttempts     Int                  @default(0)
  lockedUntil             DateTime?            // Null = not locked
  // ---- Session management ----
  tokenVersion            Int                  @default(0) // Increment to invalidate ALL refresh tokens
  attendanceMarked        Attendance[]         @relation("AttendanceMarker")
  attendanceOverridden    AttendanceOverride[]
  classSubjectAssignments ClassSubject[]
  paymentsRecorded        FeePayment[]         @relation("PaymentsRecorder")
  gradesApproved          Grade[]              @relation("GradeApprovedBy")
  gradesEntered           Grade[]              @relation("GradeEnteredBy")
  parentRelations         ParentStudent[]      @relation("ParentRelation")
  studentRelations        ParentStudent[]      @relation("StudentRelation")
  passwordResetTokens     PasswordResetToken[]
  refreshTokens           RefreshToken[]
  auditLogs               AuditLog[]
  studentProfile          StudentProfile?
  taughtSlots             TimetableSlot[]
  school                  School?              @relation(fields: [schoolId], references: [id])

  @@unique([email, schoolId])
  @@unique([username, schoolId])
  @@index([schoolId, isDeleted])
  @@index([role, isDeleted])
  @@index([schoolId, role, isDeleted])
  @@index([isDeleted, createdAt])
  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt]) // Fast cleanup of expired tokens per user
  @@map("password_reset_tokens")
}

// Stores hashed refresh tokens so they can be individually revoked
// and rotation attacks can be detected via the family chain
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique // Store SHA-256 hash, never the raw token
  family    String    // Shared across the rotation chain — reuse = attack detected
  expiresAt DateTime
  revokedAt DateTime? // Null = still valid
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([family])
  @@index([expiresAt]) // For cleanup jobs
  @@map("refresh_tokens")
}

// Tamper-evident log of security-relevant events
model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  // Null for failed logins where user is unknown
  schoolId  String?
  event     String   // LOGIN_SUCCESS | LOGIN_FAILED | LOGOUT | PASSWORD_RESET | ACCOUNT_LOCKED | TOKEN_REVOKED
  ipAddress String?
  userAgent String?
  metadata  Json?    // Extra context (e.g., role, schoolCode used)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([schoolId, createdAt])
  @@index([event, createdAt])
  @@map("audit_logs")
}

model AcademicYear {
  id        String   @id @default(uuid())
  schoolId  String
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)
  school    School   @relation(fields: [schoolId], references: [id])
  classes   Class[]
  grades    Grade[]
  terms     Term[]

  @@map("academic_years")
}

model Term {
  id             String          @id @default(uuid())
  schoolId       String
  academicYearId String
  name           String
  startDate      DateTime
  endDate        DateTime
  isCurrent      Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  isDeleted      Boolean         @default(false)
  attendance     Attendance[]
  feeStructures  FeeStructure[]
  grades         Grade[]
  invoices       Invoice[]
  academicYear   AcademicYear    @relation(fields: [academicYearId], references: [id])
  school         School          @relation(fields: [schoolId], references: [id])
  timetableSlots TimetableSlot[]

  @@map("terms")
}

model Class {
  id              String           @id @default(uuid())
  schoolId        String
  name            String
  stream          String?
  displayName     String
  academicYearId  String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  isDeleted       Boolean          @default(false)
  attendance      Attendance[]
  classSubjects   ClassSubject[]
  academicYear    AcademicYear     @relation(fields: [academicYearId], references: [id])
  school          School           @relation(fields: [schoolId], references: [id])
  feeStructures   FeeStructure[]
  grades          Grade[]
  studentProfiles StudentProfile[]
  timetableSlots  TimetableSlot[]

  @@map("classes")
}

model Subject {
  id             String          @id @default(uuid())
  schoolId       String
  name           String
  code           String
  isCore         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  isDeleted      Boolean         @default(false)
  caMax          Float?          @default(30)
  examMax        Float?          @default(70)
  gradingScaleId String?
  attendance     Attendance[]
  classSubjects  ClassSubject[]
  grades         Grade[]
  gradingScale   GradingScale?   @relation(fields: [gradingScaleId], references: [id])
  school         School          @relation(fields: [schoolId], references: [id])
  timetableSlots TimetableSlot[]

  @@map("subjects")
}

model ClassSubject {
  id        String   @id @default(uuid())
  classId   String
  subjectId String
  teacherId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)
  class     Class    @relation(fields: [classId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id])
  teacher   User?    @relation(fields: [teacherId], references: [id])

  @@unique([classId, subjectId])
  @@index([teacherId, isDeleted])
  @@index([classId, isDeleted])
  @@map("class_subjects")
}

model TimetableSlot {
  id           String    @id @default(uuid())
  schoolId     String
  classId      String
  subjectId    String
  teacherId    String
  day          DayOfWeek
  periodNumber Int
  room         String?
  termId       String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isDeleted    Boolean   @default(false)
  class        Class     @relation(fields: [classId], references: [id])
  school       School    @relation(fields: [schoolId], references: [id])
  subject      Subject   @relation(fields: [subjectId], references: [id])
  teacher      User      @relation(fields: [teacherId], references: [id])
  term         Term      @relation(fields: [termId], references: [id])

  @@unique([classId, day, periodNumber, termId])
  @@index([schoolId, isDeleted])
  @@index([teacherId, isDeleted])
  @@index([classId, termId, isDeleted])
  @@map("timetable_slots")
}

model StudentProfile {
  id              String        @id @default(uuid())
  userId          String        @unique
  schoolId        String
  admissionNumber String
  classId         String
  dateOfBirth     DateTime?
  gender          String?
  boardingStatus  String        @default("day")
  enrollmentDate  DateTime      @default(now())
  status          StudentStatus @default(active)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  isDeleted       Boolean       @default(false)
  attendance      Attendance[]
  grades          Grade[]
  invoices        Invoice[]
  class           Class         @relation(fields: [classId], references: [id])
  school          School        @relation(fields: [schoolId], references: [id])
  user            User          @relation(fields: [userId], references: [id])

  @@unique([admissionNumber, schoolId])
  @@index([schoolId, isDeleted])
  @@index([classId, isDeleted])
  @@map("student_profiles")
}

model ParentStudent {
  id            String   @id @default(uuid())
  parentUserId  String
  studentUserId String
  relationship  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  isDeleted     Boolean  @default(false)
  parent        User     @relation("ParentRelation", fields: [parentUserId], references: [id])
  student       User     @relation("StudentRelation", fields: [studentUserId], references: [id])

  @@unique([parentUserId, studentUserId])
  @@map("parent_students")
}

model Attendance {
  id           String               @id @default(uuid())
  schoolId     String
  studentId    String
  classId      String
  subjectId    String?
  type         AttendanceType
  date         DateTime             @db.Date
  periodNumber Int?
  status       AttendanceStatus
  reason       String?
  markedBy     String
  termId       String
  isLocked     Boolean              @default(false)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  isDeleted    Boolean              @default(false)
  class        Class                @relation(fields: [classId], references: [id])
  marker       User                 @relation("AttendanceMarker", fields: [markedBy], references: [id])
  school       School               @relation(fields: [schoolId], references: [id])
  student      StudentProfile       @relation(fields: [studentId], references: [id])
  subject      Subject?             @relation(fields: [subjectId], references: [id])
  term         Term                 @relation(fields: [termId], references: [id])
  overrides    AttendanceOverride[]

  @@unique([studentId, date, type, periodNumber])
  @@index([schoolId, date, isDeleted])
  @@index([classId, date, isDeleted])
  @@index([studentId, termId, isDeleted])
  @@map("attendance")
}

model AttendanceOverride {
  id           String           @id @default(uuid())
  attendanceId String
  overriddenBy String
  oldStatus    AttendanceStatus
  newStatus    AttendanceStatus
  reason       String
  createdAt    DateTime         @default(now())
  attendance   Attendance       @relation(fields: [attendanceId], references: [id])
  overrider    User             @relation(fields: [overriddenBy], references: [id])

  @@map("attendance_overrides")
}

model Grade {
  id               String         @id @default(uuid())
  schoolId         String
  studentId        String
  subjectId        String
  classId          String
  termId           String
  academicYearId   String
  caMark           Float?
  caMax            Float          @default(30)
  examMark         Float?
  examMax          Float          @default(70)
  totalMark        Float?
  gradeLetter      String?
  position         Int?
  submissionStatus GradeStatus    @default(draft)
  enteredBy        String
  approvedBy       String?
  lockedAt         DateTime?
  rejectionComment String?
  isPublished      Boolean        @default(false)
  publishedAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  isDeleted        Boolean        @default(false)
  academicYear     AcademicYear   @relation(fields: [academicYearId], references: [id])
  approver         User?          @relation("GradeApprovedBy", fields: [approvedBy], references: [id])
  class            Class          @relation(fields: [classId], references: [id])
  enterer          User           @relation("GradeEnteredBy", fields: [enteredBy], references: [id])
  school           School         @relation(fields: [schoolId], references: [id])
  student          StudentProfile @relation(fields: [studentId], references: [id])
  subject          Subject        @relation(fields: [subjectId], references: [id])
  term             Term           @relation(fields: [termId], references: [id])

  @@unique([studentId, subjectId, termId])
  @@index([schoolId, termId, isDeleted])
  @@index([classId, subjectId, termId, isDeleted])
  @@index([enteredBy, isDeleted])
  @@map("grades")
}

model GradingScale {
  id        String        @id @default(uuid())
  schoolId  String
  name      String
  isDefault Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  isDeleted Boolean       @default(false)
  rules     GradingRule[]
  school    School        @relation(fields: [schoolId], references: [id])
  subjects  Subject[]

  @@index([schoolId, isDeleted])
  @@map("grading_scales")
}

model GradingRule {
  id             String       @id @default(uuid())
  gradingScaleId String
  gradeSymbol    String
  minPercentage  Float
  maxPercentage  Float
  classification String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  scale          GradingScale @relation(fields: [gradingScaleId], references: [id], onDelete: Cascade)

  @@index([gradingScaleId])
  @@map("grading_rules")
}

model FeeStructure {
  id          String    @id @default(uuid())
  schoolId    String    @map("school_id")
  classId     String    @map("class_id")
  termId      String    @map("term_id")
  tuitionFee  Float     @map("tuition_fee")
  boardingFee Float     @default(0) @map("boarding_fee")
  otherFee    Float     @default(0) @map("other_fee")
  totalAmount Float     @map("total_amount")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  class       Class     @relation(fields: [classId], references: [id])
  school      School    @relation(fields: [schoolId], references: [id])
  term        Term      @relation(fields: [termId], references: [id])
  invoices    Invoice[]

  @@unique([classId, termId])
  @@index([schoolId, isDeleted])
  @@map("fee_structures")
}

model Invoice {
  id             String         @id @default(uuid())
  schoolId       String         @map("school_id")
  studentId      String         @map("student_id")
  termId         String         @map("term_id")
  feeStructureId String?        @map("fee_structure_id")
  amountBilled   Float          @map("amount_billed")
  amountPaid     Float          @default(0) @map("amount_paid")
  balance        Float
  status         String         @default("unpaid")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  isDeleted      Boolean        @default(false) @map("is_deleted")
  payments       FeePayment[]
  feeStructure   FeeStructure?  @relation(fields: [feeStructureId], references: [id])
  school         School         @relation(fields: [schoolId], references: [id])
  student        StudentProfile @relation(fields: [studentId], references: [id])
  term           Term           @relation(fields: [termId], references: [id])

  @@unique([studentId, termId])
  @@index([schoolId, isDeleted])
  @@index([studentId, isDeleted])
  @@map("invoices")
}

model FeePayment {
  id              String   @id @default(uuid())
  schoolId        String   @map("school_id")
  invoiceId       String   @map("invoice_id")
  amount          Float
  receiptNumber   String   @map("receipt_number")
  paymentDate     DateTime @default(now()) @map("payment_date")
  paymentMethod   String   @map("payment_method")
  referenceNumber String?  @map("reference_number")
  recordedBy      String   @map("recorded_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  isDeleted       Boolean  @default(false) @map("is_deleted")
  invoice         Invoice  @relation(fields: [invoiceId], references: [id])
  recordedByUser  User     @relation("PaymentsRecorder", fields: [recordedBy], references: [id])
  school          School   @relation(fields: [schoolId], references: [id])

  @@unique([receiptNumber, schoolId])
  @@index([schoolId, isDeleted])
  @@index([invoiceId, isDeleted])
  @@map("fee_payments")
}

enum SchoolType {
  secondary
  primary
  mixed
}

enum UserRole {
  super_admin
  director
  school_director
  it_coordinator
  head_teacher
  deputy_head
  teacher
  bursar
  student
  parent
}

enum DayOfWeek {
  Mon
  Tue
  Wed
  Thu
  Fri
}

enum StudentStatus {
  active
  suspended_fees
  suspended_discipline
  graduated
  withdrawn
}

enum AttendanceType {
  morning
  period
}

enum AttendanceStatus {
  present
  absent
  late
}

enum GradeStatus {
  draft
  submitted
  approved
  locked
}
